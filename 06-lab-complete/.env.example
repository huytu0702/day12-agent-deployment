# Copy this file to .env for local runs.
# Do not commit the real .env file.

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

APP_NAME=Day12 Production Agent
APP_VERSION=2.0.0
LLM_MODEL=mock-gpt-4o-mini

REDIS_URL=redis://localhost:6379/0
AGENT_API_KEY=replace-with-a-long-random-value
ALLOWED_ORIGINS=*

RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
HISTORY_LIMIT=20
CONVERSATION_TTL_SECONDS=604800
